    },

    "無料プランでもシールは作れますか？" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Can I create stickers on the free plan?" } }
      }
    },

    "はい。無料プランではシール30枚・ボード1枚まで作成できます。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Yes. The free plan allows up to 30 stickers and 1 board." } }
      }
    },

    "Proプランはいつでも解約できますか？" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Can I cancel the Pro plan at any time?" } }
      }
    },

    "はい。いつでも解約可能です。解約後も有効期限まではPro機能をご利用いただけます。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Yes. You can cancel at any time. Pro features remain available until the expiration date." } }
      }
    },

    "機種変更してもProは引き継げますか？" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Will Pro carry over to a new device?" } }
      }
    },

    "はい。同じApple IDでサインインし「購入を復元」を行うと引き継げます。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Yes. Sign in with the same Apple ID and tap Restore Purchases." } }
      }
    },

    "月額と年額はどちらがお得ですか？" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Which is better value, monthly or yearly?" } }
      }
    },

    "年額プランのほうがおトクです。詳しい割引率は上のプランカードをご確認ください。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "The yearly plan offers better value. See the plan cards above for discount details." } }
      }
    },

    "β機能" : {
      "localizations" : {
