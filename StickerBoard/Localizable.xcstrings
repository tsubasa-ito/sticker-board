    "注意事項" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Important Notes" } }
      }
    },

    "有効期限終了の24時間前までに解約されない限り、自動的に継続購入となります。" : {
      "localizations" : {
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Subscriptions automatically renew unless cancelled at least 24 hours before the end of the current period." } }
